# VITE_API_URL is only used for production builds (`vite build`).
# `npm run dev` always uses /api → Vite proxy → localhost:5000 (ignores this file).

# For a production build that talks to your deployed API:
# VITE_API_URL=https://your-api.onrender.com/api

# Local production preview without proxy:
# VITE_API_URL=http://localhost:5000/api
